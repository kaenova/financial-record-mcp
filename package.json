{
  "name": "catatan-keuangan-mcp",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run start",
    "build": "xmcp build && bun build ./src/index.ts --target=bun --outdir=./dist",
    "start": "xmcp build && bun run ./src/index.ts",
    "docker:build": "docker build -t catatan-keuangan-mcp .",
    "docker:run": "docker compose up"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "googleapis": "^171.4.0",
    "xmcp": "^0.6.10",
    "zod": "^4.4.3"
  }
}
