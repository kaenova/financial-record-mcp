# === Google Sheets Configuration ===
# Base64-encoded Google Service Account JSON key
SERVICE_ACCOUNT_JSON_BASE64=
# Google Sheet ID (from the sheet URL: https://docs.google.com/spreadsheets/d/<ID>/edit)
GOOGLE_SHEET_ID=
# Name of the sheet/tab within the spreadsheet (default: "Form Responses 1")
GOOGLE_SHEET_NAME=Form Responses 1
# Prefix for temporary query sheets (e.g., "QUERY_")
GOOGLE_SHEET_QUERY_PREFIX=QUERY_

# === Authentication ===
# API key required for every request (via Authorization: Bearer <key> or x-api-key: <key>)
MCP_KEY=

# === Server ===
# Port to listen on (default: 8081)
PORT=8081
# Host to bind to (default: 0.0.0.0)
HOST=0.0.0.0
# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info